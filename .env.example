# ============================================================
# 配置模板：复制此文件为 .env 并填入真实值
#   cp .env.example .env
# ============================================================

# ============ Tushare ============
# 在 https://tushare.pro/user/token 获取
TUSHARE_TOKEN=your_tushare_token_here

# ============ MySQL ============
# 用专用用户连接，不要用 root
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=gupiao_app
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=gupiao

# ============ Web 服务 ============
WEB_HOST=0.0.0.0
WEB_PORT=8000
# 生产建议 false，开发可设 true
DEBUG=false

# ============ 定时任务 ============
# 北京时间，HH:MM 格式
SCHEDULE_FIRST_RUN=17:30
SCHEDULE_SECOND_RUN=19:00
SCHEDULE_THIRD_RUN=19:30

# ============ 数据策略 ============
# 历史数据保留天数（建议 500，覆盖2年）
HISTORY_DAYS=500
# 全市场扫描的最低数据要求（少于此天数的票跳过）
MIN_DATA_DAYS=60

# ============ 接口频控 ============
# tushare 海外节点稍慢，保守一些
RATE_LIMIT_INTERVAL=1.0
RATE_LIMIT_PER_MINUTE=80

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_DIR=logs

# ============ 报告归档 ============
REPORT_DIR=reports
